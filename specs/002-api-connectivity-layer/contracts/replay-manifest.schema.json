{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://figma-2-react.specs/002/replay-manifest.schema.json",
  "title": "Replay Manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "fileKey",
    "nodeId",
    "createdAt",
    "generatorVersion",
    "hash",
    "segments"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^1\\.[0-9]+\\.[0-9]+$"
    },
    "fileKey": {
      "type": "string",
      "minLength": 5
    },
    "nodeId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "generatorVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+"
    },
    "hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{8}$"
    },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "request",
          "response",
          "sha1",
          "source"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "request": {
            "type": "object",
            "required": ["method", "path", "query", "headers"],
            "properties": {
              "method": { "type": "string" },
              "path": { "type": "string" },
              "query": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              },
              "headers": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              }
            },
            "additionalProperties": false
          },
          "response": {
            "type": "object",
            "required": ["status", "bodyPath", "headers", "recordedAt"],
            "properties": {
              "status": { "type": "integer", "minimum": 100, "maximum": 599 },
              "bodyPath": { "type": "string" },
              "headers": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              },
              "recordedAt": { "type": "string", "format": "date-time" }
            },
            "additionalProperties": false
          },
          "sha1": {
            "type": "string",
            "pattern": "^[a-f0-9]{40}$"
          },
          "source": {
            "type": "string",
            "enum": ["network", "replay"]
          }
        },
        "additionalProperties": false
      }
    },
    "notes": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": false
}
