{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VersionRecord",
  "type": "object",
  "required": ["versionDir","runTimestamp","fileHashes"],
  "properties": {
    "versionDir": {"type":"string"},
    "baseComponent": {"type":"string"},
    "runTimestamp": {"type":"string","format":"date-time"},
    "previousVersionDir": {"type":["string","null"]},
    "fileHashes": {"type":"object","additionalProperties":{"type":"string"}}
  }
}
